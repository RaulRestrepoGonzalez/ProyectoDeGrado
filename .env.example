# ========================================
# CONFIGURACION FLUTTER - MUSICAPP VALLEDUPAR
# ========================================

# URL del backend API
# Para desarrollo local con emulador Android:
BASE_URL=http://192.168.1.9:3000/api

# Para desarrollo web/localhost:
# BASE_URL=http://localhost:3000/api

# Para emulador Android (si funciona):
# BASE_URL=http://10.0.2.2:3000/api

# Socket.IO para tiempo real
SOCKET_URL=http://192.168.1.9:4000

# Hosts alternativos (separados por coma)
# La app probará automáticamente estos hosts si el principal falla
BASE_HOSTS=192.168.1.9,localhost,10.0.2.2,10.0.3.2,127.0.0.1

# Timeouts de red (milisegundos)
NETWORK_TIMEOUT=15000
RETRY_ATTEMPTS=8

# ========================================
# INSTRUCCIONES DE CONFIGURACION
# ========================================
#
# 1. Obtener tu IP local:
#    - Windows: Ejecuta "ipconfig" en CMD
#    - Linux/Mac: Ejecuta "ifconfig" o "ip addr"
#
# 2. Reemplazar 192.168.1.9 con TU IP real
#
# 3. Si usas emulador Android:
#    - Prueba primero con 10.0.2.2
#    - Si no funciona, usa tu IP local
#
# 4. Verificar conectividad:
#    - Ejecuta: .\test_conectividad.bat
#    - O curl http://[TU_IP]:3000/health
#
# ========================================
